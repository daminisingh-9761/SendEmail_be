# --- App ---
ENV=development
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql+asyncpg://mailjob:mailjob@localhost:5432/mailjob

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Google OAuth (login) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Gmail sending: we use the user's own OAuth token with gmail.send scope
# so application emails come from the user's own inbox, not a shared address.
GOOGLE_SEND_SCOPES=https://www.googleapis.com/auth/gmail.send

# --- AI provider (choose one) ---
AI_PROVIDER=openai            # openai | gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# --- Storage for uploaded resumes / job files ---
STORAGE_BACKEND=local         # local | s3
STORAGE_LOCAL_DIR=./uploads
S3_BUCKET=
S3_REGION=
